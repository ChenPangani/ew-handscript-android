cd /Users/iMac/Projects/ew-handscript-android
cat > .gitignore << 'EOF'
# ================================================================
# 1. Android & Gradle 构建产物（核心）
# ================================================================
*.apk
*.ap_
*.aab
*.dex
*.class
bin/
gen/
out/
build/
.gradle/
gradle-app.setting
local.properties
.externalNativeBuild
.cxx/
captures/

# 保留gradle wrapper（必须）
!gradle-wrapper.jar
!**/src/main/**/gradle-wrapper.jar
!**/src/test/**/gradle-wrapper.jar

# ================================================================
# 2. IDE 配置（个人化，不共享）
# ================================================================
.idea/
*.iml
*.iws
*.ipr

# ================================================================
# 3. AI 编辑器缓存（防膨胀）
# ================================================================
.cursor/
.cursorrules
.trae/
.vscode/
.augment/
.windsurf/

# ================================================================
# 4. 签名、日志与测试产物
# ================================================================
.signing/
*.jks
*.keystore
*.log
*.hprof
*.trace
*.gs
*.gcno
*.gcda

# Lint & Crashlytics
lint-results*.xml
lint-results*.html
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# ================================================================
# 5. Python 缓存（新增！Trae沙箱/算法脚本）
# ================================================================
__pycache__/
*.pyc
*.pyo
*.egg-info/
.Python
.env/
.venv/
pip-log.txt
*.keras/          # TensorFlow Keras缓存
.onnx/             # ONNX转换缓存

# ================================================================
# 6. 训练数据与中间模型（体积大，可重建）
# ================================================================
# 所有训练数据目录（图片/手写稿）
algorithm/ehs_tflite/data/
!algorithm/ehs_tflite/data/.gitkeep   # 保留空目录标记（可选）

# 所有中间模型（PyTorch/ONNX/SavedModel）
algorithm/ehs_tflite/checkpoints/*.pth
algorithm/ehs_tflite/checkpoints/*.onnx
algorithm/ehs_tflite/checkpoints/saved_model/
algorithm/ehs_tflite/checkpoints/*.keras

# 算法输出目录
docs/algorithm/ehs_algorithm/output/
!docs/algorithm/ehs_algorithm/output/.gitkeep

# ================================================================
# 7. 系统垃圾
# ================================================================
.DS_Store
Thumbs.db
Desktop.ini

# ================================================================
# 8. 个人备份（你的专属隔离区）
# ================================================================
_Archive/
*.bak
*_bak/
data_bak/
EOF

git add .gitignore
git commit -m "fix: 优化.gitignore，完善Python缓存/训练数据/算法输出忽略规则"
git push origin main
# 保留 Android 资产目录中的模型文件（核心资产，不可删）
!app/src/main/assets/models/
!app/src/main/assets/models/*.tflite
